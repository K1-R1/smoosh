root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

[smoosh]
indent_style = space
indent_size = 2
shell_variant = bash

[*.{sh,bash,bats}]
indent_style = space
indent_size = 2
shell_variant = bash

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
