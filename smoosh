# Scan category globals — populated by scan_repo_types().
SCAN_DOCS_COUNT=0
SCAN_CODE_COUNT=0
SCAN_CONFIG_COUNT=0
SCAN_OTHER_COUNT=0
SCAN_DOCS_EXTS=""
SCAN_CODE_EXTS=""
SCAN_CONFIG_EXTS=""
SCAN_OTHER_EXTS=""
SCAN_TOTAL=0

# Config/data file extensions for interactive categorisation.
# (Separate from CODE_EXTS_EXTRA which includes them for processing purposes.)
readonly SCAN_CONFIG_EXT_LIST="json yaml yml toml ini cfg conf lock env"

# is_interactive
# Returns 0 (true) when all of: stdin is TTY, stdout is TTY, zero original
# arguments were supplied, and --no-interactive was not set.
is_interactive() {
  [[ -t 0 ]] && [[ -t 1 ]] && [[ "${ORIG_ARGC}" -eq 0 ]] && [[ "${NO_INTERACTIVE}" != "true" ]]
}

# classify_file_ext EXT
# Prints the category (docs|code|config|other) for a file extension.
classify_file_ext() {
  local ext="${1}"
  [[ -z "${ext}" ]] && {
    printf 'other'
    return
  }
  case " ${DOCS_EXTS} " in
  *" ${ext} "*)
    printf 'docs'
    return
    ;;
  esac
  case " ${SCAN_CONFIG_EXT_LIST} " in
  *" ${ext} "*)
    printf 'config'
    return
    ;;
  esac
  case " ${CODE_EXTS_EXTRA} " in
  *" ${ext} "*)
    printf 'code'
    return
    ;;
  esac
  printf 'other'
}

# _scan_add_ext CATEGORY EXT
# Append EXT to the SCAN_*_EXTS string for CATEGORY, if not already present.
_scan_add_ext() {
  local cat="${1}" ext="${2}"
  case "${cat}" in
  docs)
    case " ${SCAN_DOCS_EXTS} " in
    *" ${ext} "*) ;;
    *) SCAN_DOCS_EXTS="${SCAN_DOCS_EXTS} ${ext}" ;;
    esac
    ;;
  code)
    case " ${SCAN_CODE_EXTS} " in
    *" ${ext} "*) ;;
    *) SCAN_CODE_EXTS="${SCAN_CODE_EXTS} ${ext}" ;;
    esac
    ;;
  config)
    case " ${SCAN_CONFIG_EXTS} " in
    *" ${ext} "*) ;;
    *) SCAN_CONFIG_EXTS="${SCAN_CONFIG_EXTS} ${ext}" ;;
    esac
    ;;
  *)
    case " ${SCAN_OTHER_EXTS} " in
    *" ${ext} "*) ;;
    *) SCAN_OTHER_EXTS="${SCAN_OTHER_EXTS} ${ext}" ;;
    esac
    ;;
  esac
}

# scan_repo_types
# Scan REPO_ROOT with git ls-files; classify each file by extension.
# Populates SCAN_*_COUNT, SCAN_*_EXTS, SCAN_TOTAL globals.
scan_repo_types() {
  SCAN_DOCS_COUNT=0
  SCAN_CODE_COUNT=0
  SCAN_CONFIG_COUNT=0
  SCAN_OTHER_COUNT=0
  SCAN_DOCS_EXTS=""
  SCAN_CODE_EXTS=""
  SCAN_CONFIG_EXTS=""
  SCAN_OTHER_EXTS=""
  SCAN_TOTAL=0

  local output_dir_prefix="${OUTPUT_DIR:-_smooshes}"
  # Strip REPO_ROOT prefix if OUTPUT_DIR is an absolute path inside the repo.
  if [[ "${output_dir_prefix}" == "${REPO_ROOT}/"* ]]; then
    output_dir_prefix="${output_dir_prefix#"${REPO_ROOT}/"}"
  elif [[ "${output_dir_prefix}" == /* ]]; then
    output_dir_prefix="" # absolute path outside repo; rel check won't match
  fi

  local rel
  while IFS= read -r -d '' rel; do
    # Skip hidden files/dirs and output directory.
    if [[ "${INCLUDE_HIDDEN}" != "true" ]]; then
      [[ "${rel}" == *"/."* ]] && continue
      [[ "${rel}" == "."* ]] && continue
    fi
    [[ -n "${output_dir_prefix}" ]] && [[ "${rel}" == "${output_dir_prefix}/"* ]] && continue

    local filename="${rel##*/}"
    local ext="${filename##*.}"
    [[ "${filename}" == "${ext}" ]] && ext="" # no dot → no extension

    local cat
    if [[ -z "${ext}" ]]; then
      cat="other"
    else
      case " ${DOCS_EXTS} " in
      *" ${ext} "*) cat="docs" ;;
      *) case " ${SCAN_CONFIG_EXT_LIST} " in
        *" ${ext} "*) cat="config" ;;
        *) case " ${CODE_EXTS_EXTRA} " in
          *" ${ext} "*) cat="code" ;;
          *) cat="other" ;;
          esac ;;
        esac ;;
      esac
    fi
    case "${cat}" in
    docs) SCAN_DOCS_COUNT=$((SCAN_DOCS_COUNT + 1)) ;;
    code) SCAN_CODE_COUNT=$((SCAN_CODE_COUNT + 1)) ;;
    config) SCAN_CONFIG_COUNT=$((SCAN_CONFIG_COUNT + 1)) ;;
    *) SCAN_OTHER_COUNT=$((SCAN_OTHER_COUNT + 1)) ;;
    esac
    [[ -n "${ext}" ]] && _scan_add_ext "${cat}" "${ext}"
    SCAN_TOTAL=$((SCAN_TOTAL + 1))
  done < <(git -C "${REPO_ROOT}" ls-files -z \
    --cached --others --exclude-standard 2>/dev/null |
    LC_ALL=C sort -z)
}

# _fmt_exts EXT_STRING
# Trim leading space, return first 4 extensions separated by commas,
# appending "+N more" if there are additional ones.
_fmt_exts() {
  local raw="${1# }" # strip leading space
  local -a arr=()
  # shellcheck disable=SC2086  # intentional word-splitting of space-separated list
  read -ra arr <<<"${raw}"
  local count="${#arr[@]}"
  if [[ "${count}" -eq 0 ]]; then
    printf '—'
    return
  fi
  local shown="${arr[0]}"
  local i
  for i in 1 2 3; do
    [[ "${i}" -ge "${count}" ]] && break
    shown="${shown}, ${arr[${i}]}"
  done
  if [[ "${count}" -gt 4 ]]; then
    shown="${shown} +$((count - 4)) more"
  fi
  printf '%s' "${shown}"
}

# show_banner
# Print the box-drawing logo and tagline to stderr.
show_banner() {
  [[ "${QUIET}" == "true" ]] && return 0

  # Build letter rows from box-drawing symbols:  s m o o s h
  local T="${SYM_TL}" R="${SYM_TR}" B="${SYM_BL}" K="${SYM_BR}"
  local H="${SYM_H}" V="${SYM_V}" J="${SYM_TJ}" U="${SYM_BJ}"
  local L="${SYM_LJ}" P="${SYM_RJ}"

  local r1="${T}${H}${R} ${T}${J}${R} ${T}${H}${R} ${T}${H}${R} ${T}${H}${R} ${J} ${J}"
  local r2="${B}${H}${R} ${V}${V}${V} ${V} ${V} ${V} ${V} ${B}${H}${R} ${L}${H}${P}"
  local r3="${B}${H}${K} ${U} ${U} ${B}${H}${K} ${B}${H}${K} ${B}${H}${K} ${U} ${U}"

  # Outer box: dim borders, bold cyan letters.
  local hline
  hline="$(printf '%0.s'"${H}" $(seq 1 27))"

  printf '\n' >&2
  printf '  %b%s%s%s%b\n' "${DIM}" "${T}" "${hline}" "${R}" "${RESET}" >&2
  printf '  %b%s%b  %b%s%b  %b%s%b\n' \
    "${DIM}" "${V}" "${RESET}" \
    "${BOLD}${SUN_1}" "${r1}" "${RESET}" \
    "${DIM}" "${V}" "${RESET}" >&2
  printf '  %b%s%b  %b%s%b  %b%s%b\n' \
    "${DIM}" "${V}" "${RESET}" \
    "${BOLD}${SUN_2}" "${r2}" "${RESET}" \
    "${DIM}" "${V}" "${RESET}" >&2
  printf '  %b%s%b  %b%s%b  %b%s%b\n' \
    "${DIM}" "${V}" "${RESET}" \
    "${BOLD}${SUN_3}" "${r3}" "${RESET}" \
    "${DIM}" "${V}" "${RESET}" >&2
  printf '  %b%s%s%s%b\n' "${DIM}" "${B}" "${hline}" "${K}" "${RESET}" >&2
  printf '\n' >&2
  printf '  %bOne command. Every doc. Smooshed.%b  %bv%s%b\n' \
    "${BOLD}${SUN_2}" "${RESET}" "${DIM}" "${VERSION}" "${RESET}" >&2
  printf '\n' >&2
}

# show_scan_table
# Print a formatted table of repo file counts by category.
show_scan_table() {
  [[ "${QUIET}" == "true" ]] && return 0

  local w_cat=6 w_files=5 w_exts=26

  draw_top_border "${w_cat}" "${w_files}" "${w_exts}"
  draw_row "$(printf '%b%-*s%b' "${BOLD}${SUN_1}" "${w_cat}" "Type" "${RESET}")" \
    "$(printf '%b%*s%b' "${BOLD}${SUN_1}" "${w_files}" "Files" "${RESET}")" \
    "$(printf '%b%-*s%b' "${BOLD}${SUN_1}" "${w_exts}" "Extensions" "${RESET}")"
  draw_separator "${w_cat}" "${w_files}" "${w_exts}"

  local docs_exts code_exts config_exts other_exts
  docs_exts="$(_fmt_exts "${SCAN_DOCS_EXTS}")"
  code_exts="$(_fmt_exts "${SCAN_CODE_EXTS}")"
  config_exts="$(_fmt_exts "${SCAN_CONFIG_EXTS}")"
  other_exts="$(_fmt_exts "${SCAN_OTHER_EXTS}")"

  if [[ "${SCAN_DOCS_COUNT}" -gt 0 ]]; then
    draw_row "$(printf '%b%-*s%b' "${SUN_2}" "${w_cat}" "Docs" "${RESET}")" \
      "$(printf '%*s' "${w_files}" "${SCAN_DOCS_COUNT}")" \
      "$(printf '%b%-*s%b' "${DIM}" "${w_exts}" "${docs_exts}" "${RESET}")"
  fi
  if [[ "${SCAN_CODE_COUNT}" -gt 0 ]]; then
    draw_row "$(printf '%b%-*s%b' "${SUN_2}" "${w_cat}" "Code" "${RESET}")" \
      "$(printf '%*s' "${w_files}" "${SCAN_CODE_COUNT}")" \
      "$(printf '%b%-*s%b' "${DIM}" "${w_exts}" "${code_exts}" "${RESET}")"
  fi
  if [[ "${SCAN_CONFIG_COUNT}" -gt 0 ]]; then
    draw_row "$(printf '%b%-*s%b' "${SUN_2}" "${w_cat}" "Config" "${RESET}")" \
      "$(printf '%*s' "${w_files}" "${SCAN_CONFIG_COUNT}")" \
      "$(printf '%b%-*s%b' "${DIM}" "${w_exts}" "${config_exts}" "${RESET}")"
  fi
  if [[ "${SCAN_OTHER_COUNT}" -gt 0 ]]; then
    draw_row "$(printf '%b%-*s%b' "${SUN_2}" "${w_cat}" "Other" "${RESET}")" \
      "$(printf '%*s' "${w_files}" "${SCAN_OTHER_COUNT}")" \
      "$(printf '%b%-*s%b' "${DIM}" "${w_exts}" "${other_exts}" "${RESET}")"
  fi

  draw_separator "${w_cat}" "${w_files}" "${w_exts}"
  draw_row "$(printf '%b%-*s%b' "${BOLD}${SUN_1}" "${w_cat}" "Total" "${RESET}")" \
    "$(printf '%b%*s%b' "${BOLD}${SUN_1}" "${w_files}" "${SCAN_TOTAL}" "${RESET}")" \
    "$(printf '%-*s' "${w_exts}" "")"
  draw_bottom_border "${w_cat}" "${w_files}" "${w_exts}"
  printf '\n' >&2
}

# prompt_choice PROMPT DEFAULT
# Print PROMPT to stderr, read a line; return DEFAULT if empty.
prompt_choice() {
  local prompt="${1}" default="${2:-}"
  printf '  %s ' "${prompt}" >&2
  local input=""
  IFS= read -r input
  if [[ -z "${input}" ]]; then
    printf '%s' "${default}"
  else
    printf '%s' "${input}"
  fi
}

# interactive_menu
# Present numbered choices, read selection, set MODE (and ONLY_PATTERNS for
# custom). Prints the equivalent CLI command as a tip.
interactive_menu() {
  printf '  What would you like to process?\n\n' >&2
  printf '  %b[1]%b Docs only      %b(md, rst, txt, ...)%b   %bsmoosh%b\n' \
    "${BOLD}${SUN_1}" "${RESET}" "${DIM}" "${RESET}" "${SUN_2}" "${RESET}" >&2
  printf '  %b[2]%b Docs + Code    %b(+ py, js, ts, ...)%b   %bsmoosh --code%b\n' \
    "${BOLD}${SUN_1}" "${RESET}" "${DIM}" "${RESET}" "${SUN_2}" "${RESET}" >&2
  printf '  %b[3]%b Everything     %b(all text files)%b      %bsmoosh --all%b\n' \
    "${BOLD}${SUN_1}" "${RESET}" "${DIM}" "${RESET}" "${SUN_2}" "${RESET}" >&2
  printf '  %b[4]%b Custom extensions\n' "${BOLD}${SUN_1}" "${RESET}" >&2
  printf '\n' >&2

  local choice
  choice="$(prompt_choice "Choice [1]:" "1")"

  # Validate — accept 1-4, default to 1 on anything else.
  case "${choice}" in
  1 | "") MODE="docs" ;;
  2) MODE="code" ;;
  3) MODE="all" ;;
  4)
    printf '\n  Extensions (comma-separated, e.g. py,js,ts): ' >&2
    local exts=""
    IFS= read -r exts
    ONLY_PATTERNS="${exts}"
    MODE="docs" # base; --only overrides in resolve_extensions
    ;;
  *) MODE="docs" ;;
  esac

  printf '\n' >&2
  local tip_cmd="smoosh"
  case "${MODE}" in
  code) tip_cmd="smoosh --code" ;;
  all) tip_cmd="smoosh --all" ;;
  esac
  if [[ -n "${ONLY_PATTERNS}" ]]; then
    tip_cmd="smoosh --only '${ONLY_PATTERNS}'"
  fi
  info "  ${SUN_2}${SYM_ARROW}${RESET} Tip: next time, run: ${BOLD}${SUN_2}${tip_cmd}${RESET}"
  printf '\n' >&2
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

# ORIG_ARGC: saved in main() before parse_args — used by is_interactive().
ORIG_ARGC=0

main() {
  ORIG_ARGC="${#}"
  # Argument parsing first (may call show_help/show_version and exit early).
  parse_args ${1+"${@}"}

  # Now set up visuals — after --no-color has been parsed.
  setup_colours
  setup_symbols

  # Phase 3: discovery — resolve_target is always needed first.
  resolve_target

  # Phase 7: interactive mode (TTY + zero original args + no --no-interactive).
  if is_interactive; then
    show_banner
    scan_repo_types
    show_scan_table
    interactive_menu
  fi

  resolve_extensions
  discover_files

  if [[ "${#FILES[@]}" -eq 0 ]]; then
    die 3 "No matching files found in ${REPO_ROOT}
Try --code for code files, --all for everything, or --include to add extensions."
  fi

  # Pre-computation runs before dry_run check so --dry-run shows word counts.
  batch_word_counts
  batch_mime_check # no-op unless --all mode
  scan_secrets     # rebuilds FILES/WORD_COUNTS; no-op if --no-check-secrets
  compute_chunk_assignments

  if [[ "${DRY_RUN}" == "true" ]]; then
    dry_run_preview # delegates to output_json when --json
    exit 0
  fi

  # Phase 4: output generation
  ensure_output_dir
  process_files
  verify_output

  if [[ "${JSON_OUTPUT}" == "true" ]]; then
    output_json
  else
    show_summary
  fi

}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main ${1+"${@}"}
fi
