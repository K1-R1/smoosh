# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

# _parse_filter_flag — called by parse_args for filter-related flags.
# Handles: --include, --only, --exclude, --include-hidden.
# Sets _SHIFT_EXTRA=1 when a value argument is consumed.
# Returns 1 when the flag is not recognised (caller falls through to main case).
_parse_filter_flag() {
  _SHIFT_EXTRA=0
  case "${1}" in
  --include)
    [[ "${#}" -lt 2 ]] && die 1 "--include requires a value (comma-separated globs)"
    [[ -z "${2//[[:space:]]/}" ]] && die 1 "--include requires a non-empty value (comma-separated globs)"
    INCLUDE_PATTERNS="${2}"
    _SHIFT_EXTRA=1
    ;;
  --only)
    [[ "${#}" -lt 2 ]] && die 1 "--only requires a value (comma-separated globs)"
    [[ -z "${2//[[:space:]]/}" ]] && die 1 "--only requires a non-empty value (comma-separated globs)"
    ONLY_PATTERNS="${2}"
    _SHIFT_EXTRA=1
    ;;
  --exclude)
    [[ "${#}" -lt 2 ]] && die 1 "--exclude requires a value (comma-separated globs)"
    [[ -z "${2//[[:space:]]/}" ]] && die 1 "--exclude requires a non-empty value (comma-separated globs)"
    EXCLUDE_PATTERNS="${2}"
    _SHIFT_EXTRA=1
    ;;
  --include-hidden)
    INCLUDE_HIDDEN=true
    ;;
  *)
    return 1
    ;;
  esac
}

# _parse_output_flag — called by parse_args for output-related flags.
# Handles: --output-dir, --max-words, --format, --toc, --line-numbers.
# Sets _SHIFT_EXTRA=1 when a value argument is consumed.
# Returns 1 when the flag is not recognised (caller falls through to main case).
_parse_output_flag() {
  _SHIFT_EXTRA=0
  case "${1}" in
  --output-dir)
    [[ "${#}" -lt 2 ]] && die 1 "--output-dir requires a path value"
    [[ "${2}" == "/" ]] && die 1 "--output-dir cannot be the filesystem root (/)"
    OUTPUT_DIR="${2}"
    _SHIFT_EXTRA=1
    ;;
  --max-words)
    [[ "${#}" -lt 2 ]] && die 1 "--max-words requires a numeric value"
    [[ "${2}" =~ ^[1-9][0-9]*$ ]] || die 1 "--max-words requires a positive integer (>0), got: ${2}"
    MAX_WORDS="${2}"
    _SHIFT_EXTRA=1
    ;;
  --format)
    [[ "${#}" -lt 2 ]] && die 1 "--format requires a value: md, text, or xml"
    case "${2}" in
    md | text | xml) FORMAT="${2}" ;;
    *) die 1 "--format must be one of: md, text, xml (got: ${2})" ;;
    esac
    _SHIFT_EXTRA=1
    ;;
  --toc)
    TOC=true
    ;;
  --line-numbers)
    LINE_NUMBERS=true
    ;;
  *)
    return 1
    ;;
  esac
}

# validate_args — post-parse cross-flag validation.
validate_args() {
  if [[ "${JSON_OUTPUT}" == "true" ]] && [[ "${QUIET}" == "true" ]]; then
    die 1 "--json and --quiet are mutually exclusive. Use one or the other."
  fi
}

parse_args() {
  while [[ "${#}" -gt 0 ]]; do
    # Normalise --flag=value to --flag value for uniform processing.
    if [[ "${1}" == --*=* ]]; then
      set -- "${1%%=*}" "${1#*=}" "${@:2}"
    fi

    if _parse_filter_flag "${@}"; then
      shift $((1 + _SHIFT_EXTRA))
      continue
    fi
    if _parse_output_flag "${@}"; then
      shift $((1 + _SHIFT_EXTRA))
      continue
    fi

    case "${1}" in
    --help | -h)
      show_help
      exit 0
      ;;
    --version)
      show_version
      exit 0
      ;;
    --docs) MODE="docs" ;;
    --code) MODE="code" ;;
    --all) MODE="all" ;;
    --no-check-secrets) NO_CHECK_SECRETS=true ;;
    --dry-run) DRY_RUN=true ;;
    --quiet) QUIET=true ;;
    --json) JSON_OUTPUT=true ;;
    --no-color) NO_COLOR_FLAG=true ;;
    --no-interactive) NO_INTERACTIVE=true ;;
    --)
      shift
      TARGET="${1-}"
      break
      ;;
    --*)
      die 1 "Unknown option: ${1}. Run smoosh --help for usage."
      ;;
    *)
      if [[ -z "${TARGET}" ]]; then
        TARGET="${1}"
      else
        die 1 "Unexpected argument: ${1}. Only one TARGET is allowed."
      fi
      ;;
    esac
    shift
  done
  validate_args
}

# ---------------------------------------------------------------------------
# Phase 3: File discovery
# ---------------------------------------------------------------------------

# get_extensions_for_mode
# Populate EFFECTIVE_EXTENSIONS from MODE. Call before resolve_extensions().
get_extensions_for_mode() {
  EFFECTIVE_EXTENSIONS=()
  case "${MODE}" in
  docs)
    # shellcheck disable=SC2086  # intentional word-splitting of extension list
    read -ra EFFECTIVE_EXTENSIONS <<<"${DOCS_EXTS}"
    ;;
  code)
    # shellcheck disable=SC2086
    read -ra EFFECTIVE_EXTENSIONS <<<"${DOCS_EXTS} ${CODE_EXTS_EXTRA}"
    ;;
  all)
    EFFECTIVE_EXTENSIONS=() # no extension filter; MIME check handles filtering
    ;;
  esac
}

# resolve_extensions
# Apply --include and --only on top of the mode extension list.
resolve_extensions() {
  get_extensions_for_mode

  if [[ -n "${ONLY_PATTERNS}" ]]; then
    # --only overrides mode entirely
    EFFECTIVE_EXTENSIONS=()
    local old_ifs="${IFS}"
    IFS=','
    local -a only_list=()
    read -ra only_list <<<"${ONLY_PATTERNS}"
    IFS="${old_ifs}"
    local pat
    for pat in "${only_list[@]+"${only_list[@]}"}"; do
      pat="${pat#\*.}"
      pat="${pat#.}"
      if [[ -n "${pat}" ]]; then EFFECTIVE_EXTENSIONS+=("${pat}"); fi
    done
    return 0
  fi

  if [[ -n "${INCLUDE_PATTERNS}" ]]; then
    local old_ifs="${IFS}"
    IFS=','
    local -a inc_list=()
    read -ra inc_list <<<"${INCLUDE_PATTERNS}"
    IFS="${old_ifs}"
    local pat
    for pat in "${inc_list[@]+"${inc_list[@]}"}"; do
      pat="${pat#\*.}"
      pat="${pat#.}"
      if [[ -n "${pat}" ]]; then EFFECTIVE_EXTENSIONS+=("${pat}"); fi
    done
  fi
}

# resolve_target
# Sets REPO_ROOT and REPO_NAME from TARGET (empty = cwd).
resolve_target() {
  if [[ -z "${TARGET}" ]]; then
    TARGET="$(pwd)"
  fi

  # URL detection — delegate to clone_remote() (Phase 8).
  case "${TARGET}" in
  https://* | http://* | git@* | github.com/* | gitlab.com/* | bitbucket.org/*)
    clone_remote "${TARGET}"
    return 0
    ;;
  esac

  if [[ ! -e "${TARGET}" ]]; then
    die 2 "Path not found: ${TARGET}"
  fi

  if ! REPO_ROOT="$(git -C "${TARGET}" rev-parse --show-toplevel 2>/dev/null)"; then
    die 2 "Not a git repository: ${TARGET}
smoosh requires git to respect .gitignore rules."
  fi

  REPO_NAME="$(basename "${REPO_ROOT}" | tr ' ' '_' | tr -cd 'A-Za-z0-9._-')"
  REPO_NAME="${REPO_NAME:-repo}"
}

# discover_files
# Populate FILES array with repo-root-relative paths matching all filters.
# Filter order: extension → --exclude path → hidden → output-dir exclusion.
discover_files() {
  FILES=()
  local output_dir_prefix="${OUTPUT_DIR:-_smooshes}"
  local rel_path

  while IFS= read -r -d '' rel_path; do
    # Step 2: Extension filter (skip in --all mode when array is empty)
    if [[ "${#EFFECTIVE_EXTENSIONS[@]}" -gt 0 ]]; then
      local matched=false
      local ext
      for ext in "${EFFECTIVE_EXTENSIONS[@]}"; do
        if [[ "${rel_path}" == *."${ext}" ]]; then
          matched=true
          break
        fi
      done
      [[ "${matched}" == "false" ]] && continue
    fi

    # Step 3: --exclude path filter (glob match against relative path)
    if [[ -n "${EXCLUDE_PATTERNS}" ]]; then
      local old_ifs="${IFS}"
      IFS=','
      local -a excl_arr=()
      read -ra excl_arr <<<"${EXCLUDE_PATTERNS}"
      IFS="${old_ifs}"
      local excluded=false
      local excl_pat
      for excl_pat in "${excl_arr[@]+"${excl_arr[@]}"}"; do
        # shellcheck disable=SC2254  # unquoted pattern for glob matching in case
        case "${rel_path}" in
        ${excl_pat}) excluded=true && break ;;
        esac
      done
      [[ "${excluded}" == "true" ]] && continue
    fi

    # Step 4: Hidden file/directory filter
    if [[ "${INCLUDE_HIDDEN}" != "true" ]]; then
      if [[ "${rel_path}" == *"/."* ]] || [[ "${rel_path}" == "."* ]]; then
        continue
      fi
    fi

    # Step 5: Exclude output directory
    if [[ "${rel_path}" == "${output_dir_prefix}/"* ]]; then
      continue
    fi

    # Skip symlinks: never follow symlinks for local repos (defence against
    # symlinks pointing outside REPO_ROOT).
    [[ -L "${REPO_ROOT}/${rel_path}" ]] && continue

    FILES+=("${rel_path}")
  done < <(git -C "${REPO_ROOT}" ls-files -z \
    --cached --others --exclude-standard |
    LC_ALL=C sort -z)
}

# dry_run_preview
# Print a preview of files that would be processed, with word counts.
# Requires WORD_COUNTS and CHUNK_ASSIGNMENT to be pre-computed.
# When --json is set, delegates to output_json() instead.
dry_run_preview() {
  if [[ "${JSON_OUTPUT}" == "true" ]]; then
    output_json
    return
  fi

  local count="${#FILES[@]}"
  local total_words=0 i
  for i in "${!FILES[@]}"; do
    total_words=$((total_words + ${WORD_COUNTS[i]-0}))
  done
  local total_tokens
  total_tokens="$(estimate_tokens "${total_words}")"

  # Count chunks: max value in CHUNK_ASSIGNMENT.
  local num_chunks=0
  for i in "${!CHUNK_ASSIGNMENT[@]}"; do
    [[ "${CHUNK_ASSIGNMENT[i]}" -gt "${num_chunks}" ]] && num_chunks="${CHUNK_ASSIGNMENT[i]}"
  done

  info ""
  info "${BOLD}${SUN_1}Dry run${RESET} — ${count} file(s) matched in ${BOLD}${SUN_1}${REPO_NAME}${RESET}"
  info ""
  for i in "${!FILES[@]}"; do
    local wc="${WORD_COUNTS[i]-0}"
    printf '  %b%s%b %-52s %b%s words%b\n' \
      "${SUN_2}" "${SYM_BULLET}" "${RESET}" "${FILES[i]}" \
      "${DIM}" "$(format_number "${wc}")" "${RESET}" >&2
  done
  info ""
  printf '  Files : %b%s%b\n' "${BOLD}${SUN_1}" "$(format_number "${count}")" "${RESET}" >&2
  printf '  Words : %b%s%b\n' "${BOLD}${SUN_1}" "$(format_number "${total_words}")" "${RESET}" >&2
  printf '  Tokens: %b~%s%b\n' "${BOLD}${SUN_1}" "$(format_number "${total_tokens}")" "${RESET}" >&2
  printf '  Chunks: %b~%s%b\n' "${BOLD}${SUN_1}" "${num_chunks}" "${RESET}" >&2
  info ""
  info "Run without ${BOLD}${SUN_2}--dry-run${RESET} to generate output."
}

# ---------------------------------------------------------------------------
# Phase 4: Pre-computation, processing, verification, summary
# ---------------------------------------------------------------------------

# ensure_output_dir
# Create the output directory and add it to .gitignore (safe append only).
ensure_output_dir() {
  local dir="${OUTPUT_DIR:-_smooshes}"
  # For remote repos output goes to USER_CWD/_smooshes (already set by
  # clone_remote). For local repos, anchor relative paths to REPO_ROOT.
  if [[ "${REMOTE_REPO}" != "true" ]] && [[ "${dir}" != /* ]]; then
    dir="${REPO_ROOT}/${dir}"
  fi
  OUTPUT_DIR="${dir}"

  # Warn if output directory is outside the repository root (local repos only).
  if [[ "${REMOTE_REPO}" != "true" ]] && [[ "${OUTPUT_DIR}" != "${REPO_ROOT}/"* ]]; then
    warn "--output-dir is outside the repository root; output will not be auto-gitignored: ${OUTPUT_DIR}"
  fi

  if [[ ! -d "${OUTPUT_DIR}" ]]; then
    mkdir -p "${OUTPUT_DIR}" || die 7 "Cannot create output directory: ${OUTPUT_DIR}"
  fi

  # Remote repos: skip .gitignore (the clone is a temp dir, not the user's repo).
  [[ "${REMOTE_REPO}" == "true" ]] && return 0

  # Compute repo-root-relative gitignore entry (skip for paths outside the repo).
  local gitignore="${REPO_ROOT}/.gitignore"
  local entry
  if [[ "${OUTPUT_DIR}" == "${REPO_ROOT}/"* ]]; then
    entry="${OUTPUT_DIR#"${REPO_ROOT}/"}"
    entry="${entry}/"
  else
    entry="${OUTPUT_DIR}/"
  fi
  if ! grep -qF -- "${entry}" "${gitignore}" 2>/dev/null; then
    local tmp
    # Create temp in REPO_ROOT so mv to .gitignore is atomic (same filesystem).
    tmp="$(mktemp "${REPO_ROOT}/.gitignore.tmp.XXXXXX")"
    register_cleanup_file "${tmp}"
    if [[ -f "${gitignore}" ]] && [[ -s "${gitignore}" ]]; then
      # Ensure trailing newline before appending.
      cp "${gitignore}" "${tmp}"
      if [[ "$(tail -c 1 "${gitignore}" | wc -c)" -gt 0 ]]; then
        printf '\n' >>"${tmp}"
      fi
    fi
    printf '%s\n' "${entry}" >>"${tmp}"
    mv "${tmp}" "${gitignore}"
    info "${SUN_2}${SYM_ARROW}${RESET} Added ${entry} to .gitignore"
  fi
}

# batch_word_counts
# Populate WORD_COUNTS indexed array. One xargs wc -w call for all files.
batch_word_counts() {
  WORD_COUNTS=()
  local list_file
  list_file="$(mktemp)"
  register_cleanup_file "${list_file}"

  local i
  for i in "${!FILES[@]}"; do
    # Null-separated paths: xargs -0 reads them safely regardless of special chars
    # (single quotes, spaces, brackets) that BSD xargs interprets as quoting metacharacters.
    printf '%s/%s\0' "${REPO_ROOT}" "${FILES[${i}]}" >>"${list_file}"
  done

  # xargs -0 splits the arg list on NUL, bypassing ARG_MAX and quoting issues.
  # wc preserves input order within each xargs batch; assign by sequential index.
  local line count idx=0
  while IFS= read -r line; do
    # Format: "  1234 /abs/path/to/file" — strip leading whitespace, take count.
    line="${line#"${line%%[! ]*}"}" # strip leading whitespace
    count="${line%% *}"             # first word = count
    WORD_COUNTS[idx]="${count}"
    idx=$((idx + 1))
  done < <(xargs -0 wc -w <"${list_file}" 2>/dev/null | grep -v ' total$')

  # Default any missing entries to 0.
  for i in "${!FILES[@]}"; do
    if [[ -z "${WORD_COUNTS[i]-}" ]]; then
      WORD_COUNTS[i]=0
    fi
  done
}

# batch_mime_check
# Populate MIME_TYPES indexed array. Only runs in --all mode.
batch_mime_check() {
  MIME_TYPES=()
  [[ "${MODE}" != "all" ]] && return 0 # extension filter is sufficient for docs/code

  command -v file >/dev/null 2>&1 || {
    die 1 "'file' command not found — required for --all mode. Install it (e.g. apt-get install file) or use --code instead of --all."
  }

  local list_file
  list_file="$(mktemp)"
  register_cleanup_file "${list_file}"

  local i
  for i in "${!FILES[@]}"; do
    # NUL-separated: safe for filenames with spaces, quotes, or special chars.
    printf '%s/%s\0' "${REPO_ROOT}" "${FILES[${i}]}" >>"${list_file}"
  done

  # xargs -0 + file -b: one MIME type per line in input order; assign sequentially.
  local mime idx=0
  while IFS= read -r mime; do
    MIME_TYPES[idx]="${mime}"
    idx=$((idx + 1))
  done < <(xargs -0 file --mime-type -b -- <"${list_file}" 2>/dev/null)

  # Verify output count matches input to catch silent `file` entry drops.
  if [[ "${idx}" -ne "${#FILES[@]}" ]]; then
    warn "MIME check: expected ${#FILES[@]} results, got ${idx} — MIME type assignments may be misaligned"
  fi

  # Remove non-text files from FILES (allowlist approach).
  local new_files=()
  local new_wc=()
  for i in "${!FILES[@]}"; do
    local mt="${MIME_TYPES[i]-}"
    case "${mt}" in
    text/* | application/json | application/xml | application/javascript | \
      application/x-shellscript | application/toml | application/yaml | \
      inode/x-empty)
      new_files+=("${FILES[${i}]}")
      new_wc+=("${WORD_COUNTS[i]-0}")
      ;;
    *)
      [[ -n "${mt}" ]] && warn "Skipping non-text file: ${FILES[${i}]} (${mt})"
      ;;
    esac
  done
  FILES=("${new_files[@]+"${new_files[@]}"}")
  WORD_COUNTS=("${new_wc[@]+"${new_wc[@]}"}")
}

# xml_escape_attr VALUE
# Escape a string for use in an XML attribute value.
xml_escape_attr() {
  local s="${1}"
  s="${s//&/&amp;}"
  s="${s//</&lt;}"
  s="${s//>/&gt;}"
  s="${s//\"/&quot;}"
  printf '%s' "${s}"
}

# estimate_tokens WORD_COUNT
# Returns estimated token count (~1.3x word count, integer math).
estimate_tokens() {
  printf '%s' "$((${1} * 13 / 10))"
}

# format_number N
# Add thousands separators: 1234567 → 1,234,567.
format_number() {
  local n="${1}" result="" len
  len="${#n}"
  local i
  for ((i = 0; i < len; i++)); do
    if ((i > 0 && (len - i) % 3 == 0)); then
      result="${result},"
    fi
    result="${result}${n:${i}:1}"
  done
  printf '%s' "${result}"
}

# write_chunk_header FD CHUNK_NUM
# Write format-specific header to file descriptor FD.
write_chunk_header() {
  local fd="${1}" chunk_num="${2}"
  local ts
  ts="$(date '+%Y-%m-%d %H:%M:%S')"
  case "${FORMAT}" in
  md)
    printf '# Repository Compilation: %s (Part %s)\n' "${REPO_NAME}" "${chunk_num}" >&"${fd}"
    printf 'Generated: %s\n\n' "${ts}" >&"${fd}"
    ;;
  text)
    printf 'Repository Compilation: %s (Part %s)\n' "${REPO_NAME}" "${chunk_num}" >&"${fd}"
    printf 'Generated: %s\n' "${ts}" >&"${fd}"
    printf '%s\n\n' "$(printf '=%.0s' {1..60})" >&"${fd}"
    ;;
  xml)
    printf '<?xml version="1.0" encoding="UTF-8"?>\n' >&"${fd}"
    printf '<smoosh repo="%s" part="%s" generated="%s">\n' \
      "$(xml_escape_attr "${REPO_NAME}")" "${chunk_num}" "${ts}" >&"${fd}"
    ;;
  esac
}

# write_chunk_footer FD
# Write format-specific closing element (XML only).
write_chunk_footer() {
  local fd="${1}"
  if [[ "${FORMAT}" == "xml" ]]; then
    printf '</smoosh>\n' >&"${fd}"
  fi
}

# add_line_numbers FILE
# Print file content to stdout with right-aligned line numbers.
# Captures via $() to strip trailing newlines — GNU nl adds one for files
# that lack it; BSD nl preserves the original. printf '%s' ensures consistent
# output on both, and the caller's printf '\n' adds exactly one.
add_line_numbers() {
  local numbered
  numbered="$(nl -ba -nrz -w4 -s' | ' -- "${1}" 2>/dev/null || cat -- "${1}")"
  printf '%s' "${numbered}"
}

# write_file_entry FD REL_PATH
# Write format-specific block for one file to file descriptor FD.
write_file_entry() {
  local fd="${1}" rel_path="${2}"
  local abs_path="${REPO_ROOT}/${rel_path}"

  case "${FORMAT}" in
  md)
    printf '\n\n---\n### File: %s\n---\n\n' "${rel_path}" >&"${fd}"
    ;;
  text)
    printf '\n\n%s\n' "${TEXT_SEP}" >&"${fd}"
    printf 'File: %s\n' "${rel_path}" >&"${fd}"
    printf '%s\n\n' "${TEXT_SEP}" >&"${fd}"
    ;;
  xml)
    printf '<file path="%s">\n<content><![CDATA[' \
      "$(xml_escape_attr "${rel_path}")" >&"${fd}"
    ;;
  esac

  if [[ "${FORMAT}" == "xml" ]]; then
    # XML CDATA: escape ]]> sequences in all content paths, including --line-numbers.
    if [[ "${LINE_NUMBERS}" == "true" ]]; then
      add_line_numbers "${abs_path}" |
        sed 's/]]>/]]]]><![CDATA[>/g' >&"${fd}"
    else
      # Pipe through sed rather than sed -- file: BSD sed does not support --
      # as end-of-options (it treats it as a literal filename, causing doubled
      # output via the || fallback).
      cat -- "${abs_path}" | sed 's/]]>/]]]]><![CDATA[>/g' >&"${fd}"
    fi
  elif [[ "${LINE_NUMBERS}" == "true" ]]; then
    add_line_numbers "${abs_path}" >&"${fd}"
  else
    cat -- "${abs_path}" >&"${fd}"
  fi
  printf '\n' >&"${fd}"

  if [[ "${FORMAT}" == "xml" ]]; then
    printf ']]></content>\n</file>\n' >&"${fd}"
  fi
}

# ---------------------------------------------------------------------------
# Phase 5: Table of Contents
# ---------------------------------------------------------------------------

# compute_chunk_assignments
# Pre-compute CHUNK_ASSIGNMENT[i] for every file using WORD_COUNTS.
# Mirrors the chunking logic in process_files so both are always in sync.
compute_chunk_assignments() {
  CHUNK_ASSIGNMENT=()
  local chunk=1 chunk_words=0 i wc
  for i in "${!FILES[@]}"; do
    wc="${WORD_COUNTS[i]-0}"
    if ((chunk_words + wc > MAX_WORDS && chunk_words > 0)); then
      chunk=$((chunk + 1))
      chunk_words=0
    fi
    CHUNK_ASSIGNMENT[i]=${chunk}
    chunk_words=$((chunk_words + wc))
  done
}

# write_toc FD CHUNK_NUM
# Write format-specific table of contents for CHUNK_NUM to file descriptor FD.
write_toc() {
  local fd="${1}" chunk_num="${2}"
  local row=1 total_words=0 file_count=0
  local i

  case "${FORMAT}" in
  md)
    printf '\n## Table of Contents\n\n' >&"${fd}"
    printf '| # | File | Words |\n' >&"${fd}"
    printf '|---|------|-------|\n' >&"${fd}"
    for i in "${!FILES[@]}"; do
      [[ "${CHUNK_ASSIGNMENT[i]-0}" -ne "${chunk_num}" ]] && continue
      local wc="${WORD_COUNTS[i]-0}"
      printf '| %d | %s | %s |\n' "${row}" "${FILES[${i}]}" \
        "$(format_number "${wc}")" >&"${fd}"
      row=$((row + 1))
      total_words=$((total_words + wc))
      file_count=$((file_count + 1))
    done
    printf '| **Total** | **%d files** | **%s** |\n\n' \
      "${file_count}" "$(format_number "${total_words}")" >&"${fd}"
    ;;
  text)
    local sep
    sep="$(printf -- '-%.0s' {1..60})"
    printf '\nTable of Contents\n%s\n\n' "${sep}" >&"${fd}"
    for i in "${!FILES[@]}"; do
      [[ "${CHUNK_ASSIGNMENT[i]-0}" -ne "${chunk_num}" ]] && continue
      local wc="${WORD_COUNTS[i]-0}"
      printf '  %3d  %-50s  %s words\n' "${row}" "${FILES[${i}]}" \
        "$(format_number "${wc}")" >&"${fd}"
      row=$((row + 1))
      total_words=$((total_words + wc))
      file_count=$((file_count + 1))
    done
    printf '\n  Total: %d files, %s words\n\n' \
      "${file_count}" "$(format_number "${total_words}")" >&"${fd}"
    ;;
  xml)
    printf '<toc>\n' >&"${fd}"
    for i in "${!FILES[@]}"; do
      [[ "${CHUNK_ASSIGNMENT[i]-0}" -ne "${chunk_num}" ]] && continue
      local wc="${WORD_COUNTS[i]-0}"
      printf '  <entry num="%d" path="%s" words="%d"/>\n' \
        "${row}" "$(xml_escape_attr "${FILES[${i}]}")" "${wc}" >&"${fd}"
      row=$((row + 1))
      total_words=$((total_words + wc))
      file_count=$((file_count + 1))
    done
    printf '  <summary files="%d" words="%d"/>\n</toc>\n' \
      "${file_count}" "${total_words}" >&"${fd}"
    ;;
  esac
}

# process_files
# Main aggregation loop — writes output chunks, populates GENERATED_CHUNKS.
GENERATED_CHUNKS=()
PROCESSED_FILES=()

process_files() {
  GENERATED_CHUNKS=()
  PROCESSED_FILES=()

  local date_str
  date_str="$(date '+%Y_%m_%d_%H_%M_%S')"

  local ext
  case "${FORMAT}" in
  md) ext="md" ;;
  text) ext="txt" ;;
  xml) ext="xml" ;;
  esac

  local chunk_num=1
  local chunk_words=0
  local output_file="${OUTPUT_DIR}/${date_str}_${REPO_NAME}_part${chunk_num}.${ext}"
  GENERATED_CHUNKS+=("${output_file}")

  exec 3>"${output_file}"
  write_chunk_header 3 "${chunk_num}"
  [[ "${TOC}" == "true" ]] && write_toc 3 "${chunk_num}"

  local total_files="${#FILES[@]}"
  local i
  for i in "${!FILES[@]}"; do
    local rel_path="${FILES[${i}]}"
    local abs_path="${REPO_ROOT}/${rel_path}"
    local file_words="${WORD_COUNTS[i]-0}"

    if [[ ! -r "${abs_path}" ]]; then
      warn "File not readable, skipping: ${rel_path}"
      continue
    fi

    # Chunking: if this file would exceed MAX_WORDS, start a new chunk.
    if ((chunk_words + file_words > MAX_WORDS && chunk_words > 0)); then
      write_chunk_footer 3
      exec 3>&-
      chunk_num=$((chunk_num + 1))
      chunk_words=0
      output_file="${OUTPUT_DIR}/${date_str}_${REPO_NAME}_part${chunk_num}.${ext}"
      GENERATED_CHUNKS+=("${output_file}")
      exec 3>"${output_file}"
      write_chunk_header 3 "${chunk_num}"
      [[ "${TOC}" == "true" ]] && write_toc 3 "${chunk_num}"
    fi

    write_file_entry 3 "${rel_path}"
    PROCESSED_FILES+=("${rel_path}")
    chunk_words=$((chunk_words + file_words))

    # Progress indication for repos with more than 20 files.
    if [[ "${QUIET}" != "true" ]] && ((total_files > 20)); then
      local done_count=$((i + 1))
      if [[ -t 2 ]]; then
        # TTY: in-place update with carriage return.
        ((done_count % 25 == 0 || done_count == total_files)) &&
          printf '\r  Processing %d/%d...' "${done_count}" "${total_files}" >&2
      else
        # Non-TTY: milestone lines at 25%, 50%, 75%, 100%.
        local pct=$((done_count * 100 / total_files))
        case "${pct}" in
        25 | 50 | 75 | 100)
          if ((done_count % (total_files / 4 + 1) == 0 || done_count == total_files)); then
            printf '  Processing %d/%d (%d%%)\n' "${done_count}" "${total_files}" "${pct}" >&2
          fi
          ;;
        esac
      fi
    fi
  done

  # Clear TTY progress line.
  [[ -t 2 ]] && [[ "${QUIET}" != "true" ]] && printf '\r%*s\r' 40 '' >&2

  write_chunk_footer 3
  exec 3>&-
}

# verify_output
# Compare expected (PROCESSED_FILES) vs actual (headers in chunks).
# On mismatch: show diff, delete partial output, exit 4.
verify_output() {
  local expected_file actual_file
  expected_file="$(mktemp)"
  actual_file="$(mktemp)"
  register_cleanup_file "${expected_file}"
  register_cleanup_file "${actual_file}"

  if [[ "${#PROCESSED_FILES[@]}" -gt 0 ]]; then
    printf '%s\n' "${PROCESSED_FILES[@]}" | LC_ALL=C sort >"${expected_file}"
  else
    : >"${expected_file}"
  fi

  # Extract file path markers from generated chunks (format-aware).
  local chunk
  for chunk in "${GENERATED_CHUNKS[@]+"${GENERATED_CHUNKS[@]}"}"; do
    case "${FORMAT}" in
    md) grep -o '^### File: .*' -- "${chunk}" | sed 's/^### File: //' ;;
    text) grep -o '^File: .*' -- "${chunk}" | sed 's/^File: //' ;;
    xml) grep -o '<file path="[^"]*"' -- "${chunk}" | sed 's/^<file path="//;s/"$//' ;;
    esac
  done | LC_ALL=C sort >"${actual_file}"

  if ! cmp -s "${expected_file}" "${actual_file}"; then
    error "Verification failed — file list mismatch:"
    diff "${expected_file}" "${actual_file}" >&2 || true
    # Delete partial outputs to avoid leaving bad state.
    local chunk
    for chunk in "${GENERATED_CHUNKS[@]+"${GENERATED_CHUNKS[@]}"}"; do
      [[ -f "${chunk}" ]] && rm -f -- "${chunk}"
    done
    exit 4
  fi

  printf '%b%s Verified: %d files, 100%% inclusion%b\n' \
    "${SUN_1}" "${SYM_CHECK}" "${#PROCESSED_FILES[@]}" "${RESET}" >&2
}

# show_summary
# Print results table to stderr, or (in quiet mode) chunk paths to stdout.
show_summary() {
  local total_words=0 total_tokens=0
  local chunk
  for chunk in "${GENERATED_CHUNKS[@]+"${GENERATED_CHUNKS[@]}"}"; do
    [[ -f "${chunk}" ]] || continue
    local w
    w="$(LC_ALL=C wc -w <"${chunk}" 2>/dev/null | tr -d ' ')"
    total_words=$((total_words + w))
    if [[ "${QUIET}" == "true" ]]; then
      # Quiet mode: output file paths to stdout, one per line.
      printf '%s\n' "${chunk}"
    else
      printf '%s\n' "  $(basename "${chunk}") — $(format_number "${w}") words" >&2
    fi
  done

  [[ "${QUIET}" == "true" ]] && return 0

  total_tokens="$(estimate_tokens "${total_words}")"

  info ""
  printf '  Files processed : %b%s%b\n' "${BOLD}${SUN_1}" "${#PROCESSED_FILES[@]}" "${RESET}" >&2
  printf '  Total words     : %b%s%b\n' "${BOLD}${SUN_1}" "$(format_number "${total_words}")" "${RESET}" >&2
  printf '  Est. tokens     : %b%s%b\n' "${BOLD}${SUN_1}" "$(format_number "${total_tokens}")" "${RESET}" >&2
  printf '  Chunks created  : %b%s%b\n' "${BOLD}${SUN_1}" "${#GENERATED_CHUNKS[@]}" "${RESET}" >&2
  info ""
  local display_dir="${OUTPUT_DIR}"
  if [[ "${display_dir}" == "${REPO_ROOT}/"* ]]; then
    display_dir="${display_dir#"${REPO_ROOT}/"}"
  fi
  printf '  %b%s Output in:%b %b%s/%b\n' \
    "${SUN_1}" "${SYM_CHECK}" "${RESET}" "${SUN_2}" "${display_dir}" "${RESET}" >&2
  info ""
  printf '  %bReady for: NotebookLM, Claude Projects, ChatGPT, RAG pipelines.%b\n' \
    "${DIM}" "${RESET}" >&2

  local chunk_count="${#GENERATED_CHUNKS[@]}"
  if ((chunk_count > 600)); then
    warn "Over 600 chunks: exceeds NotebookLM Ultra limit (600 sources)."
  elif ((chunk_count > 300)); then
    warn "Over 300 chunks: exceeds NotebookLM Plus limit (300 sources)."
  elif ((chunk_count > 50)); then
    warn "Over 50 chunks: exceeds NotebookLM free limit (50 sources)."
  fi
}

