#!/usr/bin/env bash
# smoosh — One command. Every doc. Smooshed.
# https://github.com/K1-R1/smoosh
# MIT Licence

set -euo pipefail

readonly VERSION="1.0.1"

# ---------------------------------------------------------------------------
# Globals — argument variables (set by parse_args, read everywhere)
# ---------------------------------------------------------------------------
MODE="docs"         # docs | code | all
INCLUDE_PATTERNS="" # comma-separated globs (adds to mode extensions)
ONLY_PATTERNS=""    # comma-separated globs (overrides mode)
EXCLUDE_PATTERNS="" # comma-separated globs (path filter)
OUTPUT_DIR=""       # default: _smooshes/ (set via --output-dir)
MAX_WORDS=450000    # words per chunk
TOC=false
LINE_NUMBERS=false
FORMAT="md" # md | text | xml
DRY_RUN=false
QUIET=false
JSON_OUTPUT=false   # --json flag
NO_COLOR_FLAG=false # --no-color CLI flag
NO_CHECK_SECRETS=false
NO_INTERACTIVE=false # --no-interactive flag
INCLUDE_HIDDEN=false # --include-hidden flag
TARGET=""            # path, URL, or empty (cwd)

# Internal signalling variable: set by _parse_filter_flag/_parse_output_flag
# to tell parse_args how many extra positional args were consumed.
_SHIFT_EXTRA=0

# Tracked exit code — used by output_json so --json output reflects the true
# exit status rather than a hardcoded 0.
EXIT_CODE=0

# Runtime state (populated during execution)
REPO_ROOT=""
REPO_NAME=""
REMOTE_REPO=false # true when target was a remote URL
USER_CWD=""       # working directory at invocation (for remote output placement)
CLONE_TEMP_DIR="" # temp dir used for remote clone

# Extension management
# Space-separated extension lists; split into arrays at runtime.
readonly DOCS_EXTS="md mdx rst txt adoc asciidoc org tex"
# shellcheck disable=SC2034  # used by get_extensions_for_mode
readonly CODE_EXTS_EXTRA="py pyi js jsx ts tsx mjs cjs rs go java kt kts swift \
  c h cpp hpp cc hh cxx cs rb php scala ex exs hs lua r R sh bash zsh sql \
  yml yaml toml json xml css scss sass less dart zig vue svelte html htm \
  pl pm clj cljs cljc edn erl hrl ml mli fs fsx jl nim cr v tf tfvars \
  proto graphql sol move"
EFFECTIVE_EXTENSIONS=() # populated by resolve_extensions()

# Pre-computation arrays (populated by batch_ functions)
# These are indexed arrays; index corresponds to position in FILES array.
FILES=()
WORD_COUNTS=()
MIME_TYPES=()
CHUNK_ASSIGNMENT=() # populated by compute_chunk_assignments()

# Pre-computed text separator for write_file_entry (text format) — avoids per-file subshell.
readonly TEXT_SEP="============================================================"

# ---------------------------------------------------------------------------
# Terminal: colours and symbols
# ---------------------------------------------------------------------------

# Colour variables — assigned by setup_colours(), used everywhere else.
RED=""
YELLOW=""
DIM=""
BOLD=""
RESET=""

# Sunset palette — 256-colour accents, assigned by setup_colours().
SUN_1="" # Gold/amber — primary accent
SUN_2="" # Orange — secondary accent
SUN_3="" # Coral — tertiary accent

setup_colours() {
  # Precedence: --no-color flag > NO_COLOR env > FORCE_COLOR env > CLICOLOR > TTY
  if [[ "${NO_COLOR_FLAG}" == "true" ]] || [[ -n "${NO_COLOR-}" ]]; then
    return 0 # leave all colour vars empty
  fi

  if [[ -n "${FORCE_COLOR-}" ]] && [[ "${FORCE_COLOR}" != "0" ]]; then
    # Force colours on — fall through to set them.
    :
  elif [[ -n "${CLICOLOR-}" ]] && [[ "${CLICOLOR}" == "0" ]]; then
    return 0
  elif [[ ! -t 1 ]]; then
    return 0 # stdout is not a TTY — no colours
  fi

  RED=$'\033[31m'
  YELLOW=$'\033[33m'
  DIM=$'\033[2m'
  BOLD=$'\033[1m'
  RESET=$'\033[0m'

  # 256-colour sunset palette (xterm-256color, iTerm2, VS Code, etc.).
  if [[ "${TERM-}" == *"256color"* ]] || [[ -n "${COLORTERM-}" ]]; then
    SUN_1=$'\033[38;5;214m'
    SUN_2=$'\033[38;5;208m'
    SUN_3=$'\033[38;5;203m'
  else
    SUN_1="${YELLOW}"
    SUN_2="${YELLOW}"
    SUN_3="${RED}"
  fi
}

# Symbol variables — assigned by setup_symbols().
SYM_CHECK=""
SYM_CROSS=""
SYM_ARROW=""
SYM_BULLET=""
SYM_WARN=""
SYM_TL=""
SYM_TR=""
SYM_BL=""
SYM_BR=""
SYM_H=""
SYM_V=""
SYM_LJ=""
SYM_RJ=""
SYM_TJ=""
SYM_BJ=""

setup_symbols() {
  # Detect UTF-8 locale. Use $'\xNN' byte sequences (Bash 3.2 compatible).
  local lc_all="${LC_ALL-}"
  local lc_ctype="${LC_CTYPE-}"
  local lang="${LANG-}"
  local locale_str="${lc_all}${lc_ctype}${lang}"

  if [[ "${locale_str}" == *"UTF-8"* ]] || [[ "${locale_str}" == *"utf-8"* ]] ||
    [[ "${locale_str}" == *"utf8"* ]]; then
    # Unicode box-drawing and symbols (UTF-8 multibyte sequences)
    SYM_CHECK=$'\xe2\x9c\x94'  # ✔
    SYM_CROSS=$'\xe2\x9c\x96'  # ✖
    SYM_ARROW=$'\xe2\x86\x92'  # →
    SYM_BULLET=$'\xe2\x80\xa2' # •
    SYM_WARN=$'\xe2\x9a\xa0'   # ⚠
    SYM_TL=$'\xe2\x94\x8c'     # ┌
    SYM_TR=$'\xe2\x94\x90'     # ┐
    SYM_BL=$'\xe2\x94\x94'     # └
    SYM_BR=$'\xe2\x94\x98'     # ┘
    SYM_H=$'\xe2\x94\x80'      # ─
    SYM_V=$'\xe2\x94\x82'      # │
    SYM_LJ=$'\xe2\x94\x9c'     # ├
    SYM_RJ=$'\xe2\x94\xa4'     # ┤
    SYM_TJ=$'\xe2\x94\xac'     # ┬
    SYM_BJ=$'\xe2\x94\xb4'     # ┴
  else
    # ASCII fallback
    SYM_CHECK="v"
    SYM_CROSS="x"
    SYM_ARROW="->"
    SYM_BULLET="*"
    SYM_WARN="!"
    SYM_TL="+"
    SYM_TR="+"
    SYM_BL="+"
    SYM_BR="+"
    SYM_H="-"
    SYM_V="|"
    SYM_LJ="+"
    SYM_RJ="+"
    SYM_TJ="+"
    SYM_BJ="+"
  fi
}

# ---------------------------------------------------------------------------
# Logging — all output to stderr
# ---------------------------------------------------------------------------

info() {
  [[ "${QUIET}" == "true" ]] && return 0
  printf '%s\n' "${*}" >&2
}

warn() {
  printf '%b%s %s%b\n' "${YELLOW}" "${SYM_WARN}" "${*}" "${RESET}" >&2
}

error() {
  printf '%b%s %s%b\n' "${RED}" "${SYM_CROSS}" "${*}" "${RESET}" >&2
}

die() {
  local exit_code="${1}"
  shift
  error "${*}"
  if [[ "${JSON_OUTPUT}" == "true" ]]; then
    local msg
    msg="$(json_escape "${*}")"
    printf '{"error": "%s", "exit_code": %d}\n' "${msg}" "${exit_code}"
  fi
  exit "${exit_code}"
}

# ---------------------------------------------------------------------------
# Cleanup registry — never overwrite traps, always use register_cleanup.
# ---------------------------------------------------------------------------
CLEANUP_ACTIONS=()
TEMP_FILES=() # temp files registered for deletion on exit

# shellcheck disable=SC2329  # called by phases that register cleanup actions
register_cleanup() {
  CLEANUP_ACTIONS+=("${1}")
}

# shellcheck disable=SC2329  # called after mktemp
register_cleanup_file() {
  TEMP_FILES+=("${1}")
}

cleanup_temp_files() {
  local f
  for f in "${TEMP_FILES[@]+"${TEMP_FILES[@]}"}"; do
    rm -f -- "${f}"
  done
}

# shellcheck disable=SC2329  # invoked indirectly via trap EXIT/INT/TERM
run_cleanup() {
  local action
  for action in "${CLEANUP_ACTIONS[@]+"${CLEANUP_ACTIONS[@]}"}"; do
    "${action}" 2>/dev/null || true
  done
}

trap run_cleanup EXIT INT TERM
register_cleanup cleanup_temp_files

# ---------------------------------------------------------------------------
# Table drawing helpers
# ---------------------------------------------------------------------------

# draw_separator COL1_WIDTH COL2_WIDTH ...
# Prints a horizontal separator line using box-drawing characters.
draw_separator() {
  local line="${SYM_LJ}"
  local i
  for i in "${@}"; do
    local seg
    seg="$(printf '%0.s'"${SYM_H}" $(seq 1 "$((i + 2))"))"
    line="${line}${seg}${SYM_TJ}"
  done
  printf '%b%s%b\n' "${DIM}" "${line%"${SYM_TJ}"}${SYM_RJ}" "${RESET}" >&2
}

# draw_top_border COL1_WIDTH COL2_WIDTH ...
draw_top_border() {
  local line="${SYM_TL}"
  local i
  for i in "${@}"; do
    local seg
    seg="$(printf '%0.s'"${SYM_H}" $(seq 1 "$((i + 2))"))"
    line="${line}${seg}${SYM_TJ}"
  done
  printf '%b%s%b\n' "${DIM}" "${line%"${SYM_TJ}"}${SYM_TR}" "${RESET}" >&2
}

# draw_bottom_border COL1_WIDTH COL2_WIDTH ...
draw_bottom_border() {
  local line="${SYM_BL}"
  local i
  for i in "${@}"; do
    local seg
    seg="$(printf '%0.s'"${SYM_H}" $(seq 1 "$((i + 2))"))"
    line="${line}${seg}${SYM_BJ}"
  done
  printf '%b%s%b\n' "${DIM}" "${line%"${SYM_BJ}"}${SYM_BR}" "${RESET}" >&2
}

# draw_row VALUE1 VALUE2 ...
# Wraps each value in vertical-bar delimiters.
draw_row() {
  local out="${DIM}${SYM_V}${RESET}"
  while [[ "${#}" -gt 0 ]]; do
    out="${out} ${1} ${DIM}${SYM_V}${RESET}"
    shift
  done
  printf '%b\n' "${out}" >&2
}

