# json_escape VALUE
# Escape a string for safe embedding in a JSON string literal.
# Pure bash — no external tools required.
json_escape() {
  local s="${1}"
  s="${s//\\/\\\\}"   # \ → \\  (must be first)
  s="${s//\"/\\\"}"   # " → \"
  s="${s//$'\n'/\\n}" # newline → \n
  s="${s//$'\r'/\\r}" # CR → \r
  s="${s//$'\t'/\\t}" # tab → \t
  printf '%s' "${s}"
}

# output_json
# Write structured JSON to stdout. All other output is suppressed to stderr.
# Handles both --dry-run and normal modes based on DRY_RUN flag.
output_json() {
  local repo
  repo="$(json_escape "${REPO_NAME}")"

  if [[ "${DRY_RUN}" == "true" ]]; then
    # Dry-run JSON: per-file list with estimated chunk assignment and word counts.
    local total_words=0 num_chunks=0 i
    for i in "${!FILES[@]}"; do
      total_words=$((total_words + ${WORD_COUNTS[i]-0}))
    done
    for i in "${!CHUNK_ASSIGNMENT[@]}"; do
      [[ "${CHUNK_ASSIGNMENT[i]}" -gt "${num_chunks}" ]] && num_chunks="${CHUNK_ASSIGNMENT[i]}"
    done
    local total_tokens
    total_tokens="$(estimate_tokens "${total_words}")"

    printf '{\n'
    printf '  "dry_run": true,\n'
    printf '  "repo": "%s",\n' "${repo}"
    printf '  "files": [\n'
    local last_i="${#FILES[@]}"
    last_i=$((last_i - 1))
    for i in "${!FILES[@]}"; do
      local path wc chunk_num
      path="$(json_escape "${FILES[i]}")"
      wc="${WORD_COUNTS[i]-0}"
      chunk_num="${CHUNK_ASSIGNMENT[i]-1}"
      if [[ "${i}" -lt "${last_i}" ]]; then
        printf '    {"path": "%s", "words": %d, "chunk": %d},\n' "${path}" "${wc}" "${chunk_num}"
      else
        printf '    {"path": "%s", "words": %d, "chunk": %d}\n' "${path}" "${wc}" "${chunk_num}"
      fi
    done
    printf '  ],\n'
    printf '  "total_words": %d,\n' "${total_words}"
    printf '  "estimated_tokens": %d,\n' "${total_tokens}"
    printf '  "estimated_chunks": %d\n' "${num_chunks}"
    printf '}\n'
    return
  fi

  # Normal JSON: processed files, generated chunks, with output metadata.
  local total_words=0
  local chunk_json="" first_chunk=true
  for chunk in "${GENERATED_CHUNKS[@]+"${GENERATED_CHUNKS[@]}"}"; do
    [[ -f "${chunk}" ]] || continue
    local w
    w="$(LC_ALL=C wc -w <"${chunk}" 2>/dev/null | tr -d ' ')"
    total_words=$((total_words + w))
    local cpath
    cpath="$(json_escape "${chunk}")"
    if [[ "${first_chunk}" == "true" ]]; then
      chunk_json="    {\"path\": \"${cpath}\", \"words\": ${w}}"
      first_chunk=false
    else
      chunk_json="${chunk_json},\n    {\"path\": \"${cpath}\", \"words\": ${w}}"
    fi
  done
  local total_tokens
  total_tokens="$(estimate_tokens "${total_words}")"

  local odir
  odir="$(json_escape "${OUTPUT_DIR}")"

  printf '{\n'
  printf '  "repo": "%s",\n' "${repo}"
  printf '  "output_dir": "%s",\n' "${odir}"
  printf '  "files_processed": %d,\n' "${#PROCESSED_FILES[@]}"
  printf '  "total_words": %d,\n' "${total_words}"
  printf '  "estimated_tokens": %d,\n' "${total_tokens}"
  printf '  "verified": true,\n'
  if [[ "${NO_CHECK_SECRETS}" == "true" ]]; then
    printf '  "secrets_scan_skipped": true,\n'
  else
    # Build secrets_excluded array from FLAGGED_PATHS (newline-separated absolute paths).
    local secrets_json="[]"
    if [[ -n "${FLAGGED_PATHS-}" ]]; then
      local first_secret=true secret_path
      secrets_json="["
      while IFS= read -r secret_path; do
        [[ -z "${secret_path}" ]] && continue
        local rel_secret escaped_secret
        rel_secret="${secret_path#"${REPO_ROOT}/"}"
        escaped_secret="$(json_escape "${rel_secret}")"
        if [[ "${first_secret}" == "true" ]]; then
          secrets_json="${secrets_json}\"${escaped_secret}\""
          first_secret=false
        else
          secrets_json="${secrets_json}, \"${escaped_secret}\""
        fi
      done <<<"${FLAGGED_PATHS}"
      secrets_json="${secrets_json}]"
    fi
    printf '  "secrets_excluded": %s,\n' "${secrets_json}"
  fi
  printf '  "chunks": [\n'
  printf '%b\n' "${chunk_json}"
  printf '  ],\n'
  printf '  "exit_code": %d\n' "${EXIT_CODE}"
  printf '}\n'
}

