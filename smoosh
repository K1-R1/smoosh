# Phase 6: Safety — Secrets Detection
# ---------------------------------------------------------------------------

# get_secret_patterns
# Populate SECRET_PATTERNS with ERE patterns for common secret formats.
SECRET_PATTERNS=()
SECRET_PATTERN_NAMES=()
GENERIC_SECRET_PAT="" # set by get_secret_patterns(), used by scan_secrets helpers
FLAGGED_PATHS=""      # set by scan_secrets(), read by _secrets_report_findings/_secrets_filter_files
get_secret_patterns() {
  SECRET_PATTERNS=(
    "AKIA[0-9A-Z]{16}"
    "-----BEGIN [A-Z ]*PRIVATE KEY-----"
    "ghp_[a-zA-Z0-9]{36}"
    "gho_[a-zA-Z0-9]{36}"
    "ghs_[a-zA-Z0-9]{36}"
    "sk-ant-api[0-9]{2}-[a-zA-Z0-9_-]{95,}"
    "sk-[a-zA-Z0-9]{32,}"
    "sk-proj-[a-zA-Z0-9_-]{20,}"
    "xox[bpars]-[0-9a-zA-Z-]+"
    "SG\\.[a-zA-Z0-9_-]{22}\\.[a-zA-Z0-9_-]{43}"
    "glpat-[a-zA-Z0-9_-]{20}"
  )
  SECRET_PATTERN_NAMES=(
    "AWS Access Key"
    "Private Key Block"
    "GitHub PAT (ghp_)"
    "GitHub OAuth Token (gho_)"
    "GitHub App Token (ghs_)"
    "Anthropic API Key"
    "OpenAI API Key"
    "OpenAI Project Key"
    "Slack Token"
    "SendGrid API Key"
    "GitLab PAT"
  )
  # Generic credential pattern — applied to non-doc files only (less noise).
  local q="'"
  GENERIC_SECRET_PAT="(password|secret|token|api_key)[[:space:]]*[=:][[:space:]]*[\"${q}][^\"${q}]{8,}"
}

# _secrets_report_findings
# Emit per-file warning lines for each matched pattern. Never prints secret values.
# Reads: FLAGGED_PATHS, REPO_ROOT, SECRET_PATTERNS, SECRET_PATTERN_NAMES, GENERIC_SECRET_PAT.
_secrets_report_findings() {
  warn ""
  warn "${SYM_WARN} Potential secrets detected:"
  warn ""
  local flagged_path rel
  while IFS= read -r flagged_path; do
    [[ -z "${flagged_path}" ]] && continue
    rel="${flagged_path#"${REPO_ROOT}/"}"

    local j
    for j in "${!SECRET_PATTERNS[@]}"; do
      local hits=""
      # '|| true' prevents pipefail when grep finds no match (exit 1).
      hits="$(grep -nE -e "${SECRET_PATTERNS[j]}" -- "${flagged_path}" 2>/dev/null |
        cut -d: -f1 | tr '\n' ',' | sed 's/,$//' || true)"
      if [[ -n "${hits}" ]]; then
        warn "  ${rel}: line(s) ${hits} — ${SECRET_PATTERN_NAMES[j]}"
      fi
    done

    # Generic pattern on non-doc files only.
    case "${rel}" in
    *.md | *.mdx | *.rst | *.adoc | *.asciidoc | *.org | *.tex) ;;
    *)
      local gen_hits=""
      gen_hits="$(grep -nE "${GENERIC_SECRET_PAT}" -- "${flagged_path}" 2>/dev/null |
        cut -d: -f1 | tr '\n' ',' | sed 's/,$//' || true)"
      if [[ -n "${gen_hits}" ]]; then
        warn "  ${rel}: line(s) ${gen_hits} — Generic credential pattern"
      fi
      ;;
    esac
  done <<<"${FLAGGED_PATHS}"

  warn ""
  warn "  ${SYM_ARROW} Flagged files excluded from output."
  warn "  ${SYM_ARROW} Note: Basic pattern scan — not a security guarantee."
  warn "  ${SYM_ARROW} For thorough scanning: gitleaks, truffleHog, Secretlint"
  warn ""
}

# _secrets_filter_files
# Remove flagged files from FILES and WORD_COUNTS arrays.
# Reads: FLAGGED_PATHS, REPO_ROOT. Modifies: FILES, WORD_COUNTS.
_secrets_filter_files() {
  local flagged_arr=()
  local flagged_path
  while IFS= read -r flagged_path; do
    [[ -n "${flagged_path}" ]] && flagged_arr+=("${flagged_path}")
  done <<<"${FLAGGED_PATHS}"

  local new_files=()
  local new_wc=()
  local i
  for i in "${!FILES[@]}"; do
    local abs="${REPO_ROOT}/${FILES[i]}"
    local skip=false
    local fp
    for fp in "${flagged_arr[@]+"${flagged_arr[@]}"}"; do
      if [[ "${abs}" == "${fp}" ]]; then
        skip=true
        break
      fi
    done
    if [[ "${skip}" == "false" ]]; then
      new_files+=("${FILES[i]}")
      new_wc+=("${WORD_COUNTS[i]-0}")
    fi
  done
  FILES=("${new_files[@]+"${new_files[@]}"}")
  WORD_COUNTS=("${new_wc[@]+"${new_wc[@]}"}")
}

# scan_secrets
# Run batch grep across FILES[]. Rebuild FILES/WORD_COUNTS without flagged files.
# Must run after batch_word_counts/batch_mime_check, before compute_chunk_assignments.
# No-op when --no-check-secrets is set.
scan_secrets() {
  [[ "${NO_CHECK_SECRETS}" == "true" ]] && return 0
  [[ "${#FILES[@]}" -eq 0 ]] && return 0

  get_secret_patterns

  # Build combined ERE alternation for fast batch pass.
  local combined="" pat
  for pat in "${SECRET_PATTERNS[@]}"; do
    if [[ -z "${combined}" ]]; then
      combined="${pat}"
    else
      combined="${combined}|${pat}"
    fi
  done

  # Write absolute paths to temp file; batch grep for specific patterns.
  local list_file
  list_file="$(mktemp)"
  register_cleanup_file "${list_file}"
  local i
  for i in "${!FILES[@]}"; do
    printf '%s\0' "${REPO_ROOT}/${FILES[i]}" >>"${list_file}"
  done
  FLAGGED_PATHS="$(xargs -0 grep -lE "${combined}" <"${list_file}" 2>/dev/null || true)"

  # Generic pattern on non-doc files only.
  local nonmd_list
  nonmd_list="$(mktemp)"
  register_cleanup_file "${nonmd_list}"
  for i in "${!FILES[@]}"; do
    case "${FILES[i]}" in
    *.md | *.mdx | *.rst | *.adoc | *.asciidoc | *.org | *.tex) ;;
    *) printf '%s\0' "${REPO_ROOT}/${FILES[i]}" >>"${nonmd_list}" ;;
    esac
  done
  if [[ -s "${nonmd_list}" ]]; then
    local more=""
    more="$(xargs -0 grep -lE "${GENERIC_SECRET_PAT}" <"${nonmd_list}" 2>/dev/null || true)"
    if [[ -n "${more}" ]]; then
      FLAGGED_PATHS="$(printf '%s\n%s\n' "${FLAGGED_PATHS}" "${more}" | LC_ALL=C sort -u)"
    fi
  fi

  [[ -z "${FLAGGED_PATHS}" ]] && return 0
  _secrets_report_findings
  _secrets_filter_files
}

