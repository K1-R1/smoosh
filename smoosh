# _normalise_url URL
# Expand bare hostnames (github.com/user/repo) to HTTPS URLs.
_normalise_url() {
  local url="${1}"
  case "${url}" in
  github.com/*) url="https://${url}" ;;
  gitlab.com/*) url="https://${url}" ;;
  bitbucket.org/*) url="https://${url}" ;;
  esac
  printf '%s' "${url}"
}

# cleanup_remote_clone
# Registered with register_cleanup; removes the temp clone directory.
cleanup_remote_clone() {
  [[ -n "${CLONE_TEMP_DIR}" ]] && rm -rf -- "${CLONE_TEMP_DIR}"
}

# clone_remote URL
# Shallow-clone URL into a temp dir with hook/symlink hardening.
# Sets REPO_ROOT, REPO_NAME, REMOTE_REPO, and OUTPUT_DIR (if not set).
clone_remote() {
  local url
  url="$(_normalise_url "${1}")"
  USER_CWD="$(pwd)"

  CLONE_TEMP_DIR="$(mktemp -d)"
  register_cleanup cleanup_remote_clone

  info "${SUN_2}${SYM_ARROW}${RESET} Cloning ${url} ..."

  # --config core.hooksPath=/dev/null disables all hooks (prevents malicious
  # code execution during clone). --config core.symlinks=false writes symlinks
  # as plain text files on all platforms, preventing actual symlink creation.
  if ! git clone --depth 1 --single-branch \
    --config core.hooksPath=/dev/null \
    --config core.symlinks=false \
    -- "${url}" "${CLONE_TEMP_DIR}" 2>&1; then
    die 5 "Failed to clone: ${url}
Check the URL is correct and you have access.
Private repos require authentication (SSH key or credential helper)."
  fi

  # Post-clone symlink safety: remove any symlinks that survived the clone.
  local lnk
  while IFS= read -r lnk; do
    warn "Removing potentially unsafe symlink: ${lnk}"
    rm -f -- "${lnk}"
  done < <(find "${CLONE_TEMP_DIR}" -type l 2>/dev/null)

  # Second-pass verification: abort if any symlinks remain after the sweep.
  local remaining_lnk
  remaining_lnk="$(find "${CLONE_TEMP_DIR}" -type l 2>/dev/null | head -1)"
  if [[ -n "${remaining_lnk}" ]]; then
    die 5 "Unsafe symlinks survived post-clone cleanup — aborting to prevent symlink traversal."
  fi

  REPO_ROOT="${CLONE_TEMP_DIR}"
  REPO_NAME="$(basename "${url%.git}" | tr ' ' '_' | tr -cd 'A-Za-z0-9._-')"
  REPO_NAME="${REPO_NAME:-repo}"
  REMOTE_REPO=true

  # Default output to user's original working directory.
  if [[ -z "${OUTPUT_DIR}" ]]; then
    OUTPUT_DIR="${USER_CWD}/_smooshes"
  fi
}

